rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email));
    }

    // The whitelist can only be managed from the Firebase console.
    match /allowed_emails/{email} {
      allow read, write: if false;
    }

    // Every approved user can only access their own vocabulary and progress.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId && isAllowed();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
